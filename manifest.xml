<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="TaskPaneApp">
  <Id>0ee25369-34c4-4610-a09d-380aba1a41b1</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>OvertimeReport</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="MB-Porter Report"/>
  <Description DefaultValue="Automated overtime dashboard for Mechanic BASE and Porter data. Builds pivot tables, KPI cards, charts, and AI-powered insights from your RawData sheet."/>
  <IconUrl DefaultValue="https://khangnguyen321.github.io/OvertimeReport/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://khangnguyen321.github.io/OvertimeReport/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://www.contoso.com/help"/>
  <AppDomains>
    <AppDomain>https://api.anthropic.com</AppDomain>
    <AppDomain>https://cdn.jsdelivr.net</AppDomain>
    <AppDomain>https://khangnguyen321.github.io</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Workbook"/>
  </Hosts>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://khangnguyen321.github.io/OvertimeReport/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Workbook">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="CommandsGroup">
                <Label resid="CommandsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://khangnguyen321.github.io/OvertimeReport/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://khangnguyen321.github.io/OvertimeReport/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://khangnguyen321.github.io/OvertimeReport/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://go.microsoft.com/fwlink/?LinkId=276812"/>
        <bt:Url id="Commands.Url" DefaultValue="https://khangnguyen321.github.io/OvertimeReport/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://khangnguyen321.github.io/OvertimeReport/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="MB-Porter Report Add-in"/>
        <bt:String id="CommandsGroup.Label" DefaultValue="Automated by Khang Nguyen"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="MB-Porter Report"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="MB-Porter Report loaded. Go to the HOME tab and click 'MB-Porter Report' to open the dashboard."/>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the MB-Porter Report dashboard"/>
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>